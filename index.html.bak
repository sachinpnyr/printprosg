            <div class="contact-icon"><i class="fas fa-envelope"></i></div>
            <div><div class="contact-item-label">Email</div><div class="contact-item-value"><a href="mailto:hello@printprosg.com">hello@printprosg.com</a></div></div>
          </div>
        </div>
        <!-- Payment methods -->
        <div class="payment-methods">
          <span>We Accept:</span>
          <div class="payment-icons">
            <span class="pay-icon paynow"><i class="fas fa-qrcode"></i> PayNow</span>
            <span class="pay-icon"><i class="fas fa-university"></i> Bank Transfer</span>
          </div>
        </div>
      </div>
      <div class="contact-form-wrap reveal">
        <form id="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="contact" />
          <p style="display:none;"><label>Don't fill this out: <input name="bot-field" /></label></p>
          <div class="form-row">
            <div class="form-group">
              <label for="name">Full Name *</label>
              <input type="text" id="name" name="name" placeholder="Your full name" required />
            </div>
            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" placeholder="your@email.com" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="phone">Phone / WhatsApp</label>
              <input type="tel" id="phone" name="phone" placeholder="+65 XXXX XXXX" />
            </div>
            <div class="form-group">
              <label for="service">Service Needed</label>
              <select id="service" name="service">
                <option value="">Select a service</option>
                <option>Name Cards</option>
                <option>Booklets / Catalogues</option>
                <option>Flyers / Brochures</option>
                <option>Banners / Signage</option>
                <option>Roll-up Banners</option>
                <option>T-shirt Printing</option>
                <option>Corporate Gifts</option>
                <option>Packaging</option>
                <option>Stickers / Labels</option>
                <option>Other</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="message">Your Message *</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us about your project — quantity, size, deadline, any special requirements..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-full">
            <i class="fas fa-paper-plane"></i> Send Enquiry
          </button>
          <div id="form-success" style="display:none; margin-top:16px; padding:16px; background:#f0fdf4; border:1px solid #bbf7d0; border-radius:10px; color:#166534; font-size:14px; font-weight:600;">
            <i class="fas fa-check-circle"></i> Thank you! We'll get back to you within 2 hours.
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

